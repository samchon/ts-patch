{
  "extends" : "../../tsconfig.base.json",
  "include" : [ "shared", "src" ],

  "compilerOptions" : {
    "rootDirs" : [ "src", "shared" ],
    "outDir" : "../../dist",
    "sourceMap" : true,
    "composite" : true,
    "declaration" : true,
    "types" : [ "node" ],

    "plugins" : [
      {
        "transform" : "./plugin.ts",
        "transformProgram" : true,
        "tsConfig" : "../../tsconfig.plugin.json"
      }
    ]
  }
}
